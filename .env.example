# Copy this file to .env and fill in real values. NEVER commit .env (it is gitignored).
# Gmail requires an App Password (not your normal password): https://myaccount.google.com/apppasswords

SENDER_EMAIL=your_sender@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
RECEIVER_EMAIL=where_to_send_alerts@example.com   # one or more, comma/semicolon separated: a@x.it, b@y.it
CC_EMAIL=                                          # optional, same format
BCC_EMAIL=                                         # optional, same format (recipients hidden from others)

# Optional but strongly recommended: activates the AI judge that filters
# already-awarded / internal-only notices (cuts false positives).
GEMINI_API_KEY=

# true  = only alert when AI confirms OR an exact CUP/CLP match is found (high precision)
# false = also alert on strong rule-based matches without AI (higher recall)
AI_VERIFICATION_REQUIRED=true

# Optional: set to a Postgres URL in production; leave empty to use local SQLite.
DATABASE_URL=
